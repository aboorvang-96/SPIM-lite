{
  "expo": {
    "name": "spim-lite",
    "slug": "spim-lite",
    "scheme": "spimlite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aboorvang96.spimlite"
    },

    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "SPIM Lite",
      "shortName": "SPIM",
      "description": "SPIM Lite - Employee Portal",
      "themeColor": "#1a2f5e",
      "backgroundColor": "#0a1628",
      "display": "standalone",
      "orientation": "portrait"
    },

    "plugins": [
      "expo-router",
      "expo-font"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3adf8c3-54ea-4935-954e-4e1cb77bbee6"
      },

      "apiBaseUrl": "https://spim-suite-production.up.railway.app"

    }
  }
}